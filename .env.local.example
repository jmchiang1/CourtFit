ANTHROPIC_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps — map view of saved locations.
# Browser key for the Maps JavaScript API (restrict to your domains / HTTP referrers).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional: a cloud-styled Map ID for Advanced Markers (defaults to DEMO_MAP_ID).
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
# Server key for the Geocoding API (address → lat/lng). May be the same project,
# but should NOT be HTTP-referrer-restricted. Falls back to the public key if unset.
GOOGLE_MAPS_API_KEY=

# US Census — trade-area demographics (ethnicity / age / income) powering the
# badminton & pickleball demand fit scores. Free key (instant):
# https://api.census.gov/data/key_signup.html. Demographics are skipped if unset.
CENSUS_API_KEY=

# Mapbox — drive-time isochrones that define each property's trade area per sport
# (respects roads/water vs. a straight-line radius). Free token:
# https://account.mapbox.com/access-tokens/. Falls back to a 5-mile radius if unset.
MAPBOX_TOKEN=
